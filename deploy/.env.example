# ─── Required Postgres credentials ──────────────────────────────────────────
# These are the credentials the in-stack postgres service uses. The server
# and worker containers construct CLAUDE_MEM_SERVER_DATABASE_URL from these
# at startup; the stack will refuse to start if any are missing.
POSTGRES_USER=claude_mem
POSTGRES_PASSWORD=                       # generate with: openssl rand -hex 24
POSTGRES_DB=claude_mem

# ─── Optional: external Redis / Valkey ───────────────────────────────────────
# Leave unset to use the in-stack valkey service (recommended).
# CLAUDE_MEM_REDIS_URL=redis://localhost:6379

# ─── Generation provider API keys (worker container) ─────────────────────────
# Without a key the worker still runs but produces no observations.
# Pick ONE provider (set CLAUDE_MEM_SERVER_PROVIDER accordingly):
#   claude       — Anthropic API key (default)
#   gemini       — Google Gemini API key
#   openrouter   — OpenRouter API key
CLAUDE_MEM_SERVER_PROVIDER=claude

# Anthropic (recommended):
ANTHROPIC_API_KEY=
# CLAUDE_MEM_ANTHROPIC_API_KEY=           # alternate name for the same key

# Optional alternative providers:
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=